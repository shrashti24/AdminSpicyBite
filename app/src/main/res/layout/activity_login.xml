<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:fillViewport="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    tools:context=".LoginActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Logo -->
        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/logo"
            android:layout_marginTop="40dp"
            android:contentDescription="App Logo"/>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Spicy Bite"
            android:textSize="40sp"
            android:fontFamily="@font/yeonsung_regular"
            android:textAlignment="center"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <!-- Subtitle -->

        <!-- Login To Your Account -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Login To Your Admin Dashboard"
            android:textColor="@color/texColor"
            android:fontFamily="@font/lato_bold"
            android:textSize="26sp"

            android:textAlignment="center"
            android:layout_marginTop="32dp"/>

        <!-- Email Input -->
        <EditText
            android:id="@+id/emailOrPhone"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="  Email"
            android:drawableStart="@drawable/mail"
            android:padding="12dp"
            android:elevation="2dp"
            android:inputType="textEmailAddress"
            android:outlineSpotShadowColor="@color/texColor"
            android:background="@drawable/edittextshape"
            android:layout_marginTop="32dp"/>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

        <!-- Password Input -->
        <EditText
            android:id="@+id/password"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="  Password"
            android:elevation="2dp"
            android:outlineSpotShadowColor="@color/texColor"
            android:drawableStart="@drawable/lock"
            android:padding="12dp"
            android:paddingEnd="45dp"
            android:background="@drawable/edittextshape"

            android:inputType="textPassword"/>
            <!-- Eye Icon -->
            <ImageView
                android:id="@+id/eyeIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/eye_off"
                android:elevation="8dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="12dp"/>

        </RelativeLayout>
        <!-- Forgot Password -->
        <TextView
            android:id="@+id/forgotpassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Forgot password?"
            android:textColor="@color/texColor"
            android:textSize="14sp"
            android:layout_gravity="end"
            android:layout_marginTop="6dp"/>

        <!-- Continue With -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Or \n Continue With"
            android:textAlignment="center"
            android:textColor="@color/texColor"
            android:fontFamily="@font/yeonsung_regular"
            android:textSize="20sp"
            android:layout_marginTop="32dp"/>

        <!-- Social Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="20dp"
            android:paddingHorizontal="24dp">
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/googlebutton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Google"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:drawableStart="@drawable/google"
                android:paddingStart="30dp"
                android:background="@drawable/edittextshape"
                android:elevation="6dp"
                android:padding="12dp"
                android:gravity="center_vertical|center_horizontal"/>
        </LinearLayout>

        <!-- Login Button -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/loginbutton"
            android:layout_width="125dp"
            android:layout_height="57dp"
            android:text="Login"
            android:textAllCaps="false"
            android:outlineSpotShadowColor="@color/texColor"
            android:fontFamily="@font/yeonsung_regular"
            android:textColor="@color/white"
            android:background="@drawable/greenbuttonshape"
            android:layout_marginTop="20dp"
            android:elevation="6dp"
            android:textSize="20sp"
            android:translationZ="6dp"/>

        <!-- Don't Have Account -->
        <TextView
            android:id="@+id/donthavebutton"
            android:fontFamily="@font/lato_bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Don't Have Account?"
            android:textColor="#4CD964"
            android:layout_marginTop="16dp"/>

        <!-- Design Credit -->
    </LinearLayout>
</ScrollView>
